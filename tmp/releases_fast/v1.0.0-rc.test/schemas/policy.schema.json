{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/policy.schema.json",
  "title": "World Runtime Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "policy_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "policy_name": {
      "type": "string",
      "minLength": 1
    },
    "policy_type": {
      "type": "string",
      "enum": ["validation", "constraint", "approval", "advisory", "safety", "compliance"]
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "event_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "action_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "connector_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "directions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["inbound", "outbound"]
          },
          "default": []
        },
        "adapters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "rule.schema.json"
      },
      "minItems": 1
    },
    "default_outcome": {
      "$ref": "common.schema.json#/$defs/policyOutcome"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "default": 100
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "effective_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "expires_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "policy_id",
    "policy_name",
    "policy_type",
    "rules",
    "default_outcome",
    "created_at",
    "version"
  ]
}
