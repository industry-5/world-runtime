{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/simulation.schema.json",
  "title": "World Runtime Simulation Run",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "simulation_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "simulation_type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "running", "completed", "failed", "cancelled"]
    },
    "base_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projection_name": {
          "type": "string",
          "minLength": 1
        },
        "projection_version": {
          "type": "string",
          "minLength": 1
        },
        "event_offset": {
          "type": "integer",
          "minimum": 0
        },
        "snapshot_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parent_simulation_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "scenario_name": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "hypothetical_events": {
      "type": "array",
      "items": {
        "$ref": "event.schema.json"
      },
      "default": []
    },
    "proposed_actions": {
      "type": "array",
      "items": {
        "$ref": "proposal.schema.json"
      },
      "default": []
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "comparison_summary": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "started_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "completed_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "created_by": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "correlation_id": {
      "$ref": "common.schema.json#/$defs/correlationRef"
    }
  },
  "required": [
    "simulation_id",
    "simulation_type",
    "status",
    "created_at"
  ]
}
