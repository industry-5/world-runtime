{
  "policy_id": "policy.reroute-cost-check",
  "policy_name": "reroute_requires_cost_check",
  "policy_type": "advisory",
  "description": "Warn when rerouting a shipment increases transport cost beyond a preferred threshold.",
  "scope": {
    "connector_ids": [
      "connector.integration.egress"
    ],
    "providers": [
      "mock.webhook"
    ],
    "directions": [
      "outbound"
    ],
    "action_types": [
      "reroute_shipment"
    ],
    "adapters": [
      "supply-network"
    ]
  },
  "rules": [
    {
      "rule_id": "rule.reroute-cost-threshold",
      "rule_name": "Reroute cost soft threshold",
      "rule_type": "condition",
      "condition": {
        "field": "proposed_action.parameters.cost_delta_percent",
        "operator": ">",
        "value": 5
      },
      "outcome": "warn",
      "message_template": "Reroute cost exceeds soft threshold.",
      "severity": "medium",
      "evaluation_mode": "deterministic",
      "created_at": "2026-03-08T10:00:00Z",
      "version": 1
    }
  ],
  "default_outcome": "allow",
  "priority": 50,
  "enabled": true,
  "effective_at": "2026-03-08T10:00:00Z",
  "created_at": "2026-03-08T10:00:00Z",
  "updated_at": "2026-03-08T10:00:00Z",
  "metadata": {
    "adapter": "supply-network"
  },
  "version": 1
}
