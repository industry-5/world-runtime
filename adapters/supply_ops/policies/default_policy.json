{
  "policy_id": "policy.supply-ops.default",
  "policy_name": "supply_ops_default_policy",
  "policy_type": "operational_governance",
  "rules": [
    {
      "rule_id": "rule.supply-ops.deny-low-fill-rate",
      "rule_name": "Deny commitment recovery below minimum fill-rate threshold",
      "rule_type": "constraint",
      "condition": {
        "field": "proposed_action.parameters.projected_fill_rate_percent",
        "operator": "<",
        "value": 95
      },
      "outcome": "deny",
      "message_template": "Projected fill rate below 95% is blocked for commitment recovery actions.",
      "evaluation_mode": "deterministic",
      "severity": "critical",
      "created_at": "2026-03-22T10:20:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.supply-ops.warn-low-inventory-cover",
      "rule_name": "Warn when post-action inventory cover is low",
      "rule_type": "advisory",
      "condition": {
        "field": "proposed_action.parameters.projected_post_action_inventory_days",
        "operator": "<",
        "value": 3
      },
      "outcome": "warn",
      "message_template": "Projected inventory cover falls below three days after the action.",
      "evaluation_mode": "deterministic",
      "severity": "medium",
      "created_at": "2026-03-22T09:00:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.supply-ops.require-approval-expedite-premium",
      "rule_name": "Require approval for high expedite premium",
      "rule_type": "approval_trigger",
      "condition": {
        "field": "proposed_action.parameters.expedite_cost_delta_percent",
        "operator": ">",
        "value": 12
      },
      "outcome": "require_approval",
      "message_template": "Supervisor approval is required when expedite premium exceeds 12%.",
      "evaluation_mode": "deterministic",
      "severity": "high",
      "created_at": "2026-03-22T09:00:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.supply-ops.require-simulation-evidence",
      "rule_name": "Require simulation evidence before commitment recovery actions",
      "rule_type": "approval_trigger",
      "condition": {
        "field": "proposed_action.parameters.simulation_completed",
        "operator": "equals",
        "value": false
      },
      "outcome": "require_approval",
      "message_template": "Run and attach simulation evidence before commitment recovery actions.",
      "evaluation_mode": "deterministic",
      "severity": "high",
      "created_at": "2026-03-22T09:00:00Z",
      "version": 1
    }
  ],
  "default_outcome": "allow",
  "created_at": "2026-03-22T09:00:00Z",
  "version": 1
}
