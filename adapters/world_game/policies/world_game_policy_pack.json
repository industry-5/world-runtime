{
  "pack_id": "pack.world-game.v1",
  "pack_name": "world_game_policy_pack",
  "policies": [
    {
      "policy_id": "policy.world-game.ecological-floor.v1",
      "policy_name": "world_game_ecological_floor",
      "policy_type": "safety",
      "rules": [
        {
          "rule_id": "rule.world-game.ecological.deny-water-collapse",
          "rule_name": "Deny severe water collapse",
          "rule_type": "constraint",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.water_security",
            "operator": "<",
            "value": 20
          },
          "outcome": "deny",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.ecological.deny-resilience-collapse",
          "rule_name": "Deny severe resilience collapse",
          "rule_type": "constraint",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.food_resilience",
            "operator": "<",
            "value": 15
          },
          "outcome": "deny",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.ecological.require-approval-emissions",
          "rule_name": "Require approval for poor emissions trajectory",
          "rule_type": "approval_trigger",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.emissions_intensity",
            "operator": "<",
            "value": 45
          },
          "outcome": "require_approval",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.ecological.warn-water-band",
          "rule_name": "Warn low water security",
          "rule_type": "advisory",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.water_security",
            "operator": "<",
            "value": 35
          },
          "outcome": "warn",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        }
      ],
      "default_outcome": "allow",
      "created_at": "2026-03-11T00:00:00Z",
      "version": 1
    },
    {
      "policy_id": "policy.world-game.equity-guardrail.v1",
      "policy_name": "world_game_equity_guardrail",
      "policy_type": "compliance",
      "rules": [
        {
          "rule_id": "rule.world-game.equity.deny-collapse",
          "rule_name": "Deny extreme equity collapse",
          "rule_type": "constraint",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.equity_score",
            "operator": "<",
            "value": 25
          },
          "outcome": "deny",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.equity.require-approval-low-equity",
          "rule_name": "Require approval for low equity path",
          "rule_type": "approval_trigger",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.equity_score",
            "operator": "<",
            "value": 42
          },
          "outcome": "require_approval",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.equity.warn-soft-floor",
          "rule_name": "Warn equity soft floor",
          "rule_type": "advisory",
          "condition": {
            "field": "proposed_action.parameters.projected_indicator_scores.equity_score",
            "operator": "<",
            "value": 55
          },
          "outcome": "warn",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        }
      ],
      "default_outcome": "allow",
      "created_at": "2026-03-11T00:00:00Z",
      "version": 1
    },
    {
      "policy_id": "policy.world-game.approval-thresholds.v1",
      "policy_name": "world_game_approval_thresholds",
      "policy_type": "approval",
      "rules": [
        {
          "rule_id": "rule.world-game.approval.total-cost",
          "rule_name": "Require approval above cost threshold",
          "rule_type": "approval_trigger",
          "condition": {
            "field": "proposed_action.parameters.total_cost",
            "operator": ">",
            "value": 8000
          },
          "outcome": "require_approval",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.approval.multi-region-impact",
          "rule_name": "Require approval for broad regional impact",
          "rule_type": "approval_trigger",
          "condition": {
            "field": "proposed_action.parameters.affected_region_count",
            "operator": ">",
            "value": 2
          },
          "outcome": "require_approval",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        },
        {
          "rule_id": "rule.world-game.approval.warn-low-composite",
          "rule_name": "Warn low projected composite",
          "rule_type": "advisory",
          "condition": {
            "field": "proposed_action.parameters.projected_composite_score",
            "operator": "<",
            "value": 50
          },
          "outcome": "warn",
          "evaluation_mode": "deterministic",
          "created_at": "2026-03-11T00:00:00Z",
          "version": 1
        }
      ],
      "default_outcome": "allow",
      "created_at": "2026-03-11T00:00:00Z",
      "version": 1
    }
  ]
}
