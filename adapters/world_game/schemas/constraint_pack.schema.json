{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/constraint_pack.schema.json",
  "title": "World Game Constraint Pack",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "constraint_pack_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "constraint_id": { "type": "string", "minLength": 1 },
          "constraint_type": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "operator": {
            "type": "string",
            "enum": ["equals", ">", "<"]
          },
          "value": {},
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          }
        },
        "required": ["constraint_id", "constraint_type", "target", "operator", "value"]
      }
    }
  },
  "required": ["constraint_pack_id", "label", "description", "constraints"]
}
