{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/scenario.schema.json",
  "title": "World Game Scenario",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "scenario_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "baseline_version": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "time_horizon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_year": { "type": "integer" },
        "years_per_turn": { "type": "integer", "minimum": 1 },
        "turn_count": { "type": "integer", "minimum": 1 }
      },
      "required": ["start_year", "years_per_turn", "turn_count"]
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "required": ["region_id", "label"]
      }
    },
    "indicator_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "indicator_definition.schema.json"
      }
    },
    "baseline_indicators": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "number"
        }
      }
    },
    "interventions": {
      "type": "array",
      "items": {
        "$ref": "intervention.schema.json"
      }
    },
    "shocks": {
      "type": "array",
      "items": {
        "$ref": "shock.schema.json"
      }
    },
    "dependency_graph": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "node_id": { "type": "string", "minLength": 1 },
              "region_id": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 }
            },
            "required": ["node_id", "region_id"]
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "edge_id": { "type": "string", "minLength": 1 },
              "from_node_id": { "type": "string", "minLength": 1 },
              "to_node_id": { "type": "string", "minLength": 1 },
              "capacity": { "type": "number", "minimum": 0 },
              "latency_turns": { "type": "integer", "minimum": 0 }
            },
            "required": ["from_node_id", "to_node_id", "capacity"]
          }
        }
      }
    },
    "resource_stocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "stock_id": { "type": "string", "minLength": 1 },
          "node_id": { "type": "string", "minLength": 1 },
          "region_id": { "type": "string", "minLength": 1 },
          "indicator_id": { "type": "string", "minLength": 1 },
          "baseline": { "type": "number" },
          "min_bound": { "type": "number" },
          "max_bound": { "type": "number" },
          "regen_rate": { "type": "number" },
          "demand_rate": { "type": "number", "minimum": 0 },
          "response_factor": { "type": "number" }
        },
        "required": ["stock_id", "region_id", "indicator_id", "baseline"]
      }
    },
    "resource_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "flow_id": { "type": "string", "minLength": 1 },
          "source_stock_id": { "type": "string", "minLength": 1 },
          "target_stock_id": { "type": "string", "minLength": 1 },
          "from_node_id": { "type": "string", "minLength": 1 },
          "to_node_id": { "type": "string", "minLength": 1 },
          "capacity": { "type": "number", "minimum": 0 },
          "loss_factor": { "type": "number", "minimum": 0, "maximum": 1 },
          "indicator_conversion": { "type": "number" }
        },
        "required": ["flow_id", "source_stock_id", "target_stock_id", "capacity"]
      }
    },
    "spillover_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "edge_id": { "type": "string", "minLength": 1 },
          "from_node_id": { "type": "string", "minLength": 1 },
          "to_node_id": { "type": "string", "minLength": 1 },
          "indicator_id": { "type": "string", "minLength": 1 },
          "source_indicator_id": { "type": "string", "minLength": 1 },
          "target_indicator_id": { "type": "string", "minLength": 1 },
          "coefficient": { "type": "number" },
          "max_abs_transfer": { "type": "number", "minimum": 0 }
        },
        "required": ["rule_id", "coefficient"]
      }
    },
    "shock_schedule": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "policy_pack_ref": { "type": "string", "minLength": 1 },
    "weights": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    },
    "equity_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region_weights": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "group_id": { "type": "string", "minLength": 1 },
              "region_ids": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "weight": { "type": "number", "minimum": 0 },
              "baseline_target": { "type": "number" }
            },
            "required": ["group_id", "region_ids"]
          }
        },
        "baseline_targets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disparity_spread": { "type": "number" },
            "weighted_variance": { "type": "number" }
          }
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": true
    },
    "live_data": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "scenario_id",
    "label",
    "description",
    "baseline_version",
    "time_horizon",
    "regions",
    "indicator_definitions",
    "baseline_indicators",
    "interventions",
    "shocks",
    "weights"
  ]
}
