{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/scenario_template.schema.json",
  "title": "World Game Scenario Template",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "string_parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "const": "string" },
        "description": { "type": "string" },
        "default": { "type": "string" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "min_length": { "type": "integer", "minimum": 0 },
        "max_length": { "type": "integer", "minimum": 0 }
      },
      "required": ["name", "type"]
    },
    "integer_parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "const": "integer" },
        "description": { "type": "string" },
        "default": { "type": "integer" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer" }
        },
        "minimum": { "type": "integer" },
        "maximum": { "type": "integer" }
      },
      "required": ["name", "type"]
    },
    "number_parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "const": "number" },
        "description": { "type": "string" },
        "default": { "type": "number" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "required": ["name", "type"]
    },
    "boolean_parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "const": "boolean" },
        "description": { "type": "string" },
        "default": { "type": "boolean" }
      },
      "required": ["name", "type"]
    },
    "template_or_int": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "region_seed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "baseline_indicators": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "required": ["region_id", "label", "baseline_indicators"]
    }
  },
  "properties": {
    "template_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "parameter_model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parameters": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/string_parameter" },
              { "$ref": "#/$defs/integer_parameter" },
              { "$ref": "#/$defs/number_parameter" },
              { "$ref": "#/$defs/boolean_parameter" }
            ]
          }
        }
      },
      "required": ["parameters"]
    },
    "scenario_id_template": { "type": "string", "minLength": 1 },
    "baseline_version_template": { "type": "string", "minLength": 1 },
    "metadata_template": {
      "type": "object",
      "additionalProperties": true
    },
    "time_horizon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_year": { "$ref": "#/$defs/template_or_int" },
        "years_per_turn": { "$ref": "#/$defs/template_or_int" },
        "turn_count": { "$ref": "#/$defs/template_or_int" }
      },
      "required": ["start_year", "years_per_turn", "turn_count"]
    },
    "region_pool": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/region_seed" }
    },
    "indicator_registry_ref_template": { "type": "string", "minLength": 1 },
    "intervention_library_ref_template": { "type": "string", "minLength": 1 },
    "shock_library_ref_template": { "type": "string", "minLength": 1 },
    "policy_pack_ref_template": { "type": "string", "minLength": 1 },
    "weights_template": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "number", "minimum": 0 },
          { "type": "string", "minLength": 1 }
        ]
      }
    },
    "success_criteria_template": {
      "type": "object",
      "additionalProperties": true
    },
    "shock_schedule_template": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "strategy_templates": {
      "type": "array",
      "items": {
        "$ref": "strategy.schema.json"
      }
    },
    "dependency_graph_template": {
      "type": "object",
      "additionalProperties": true
    },
    "resource_stocks_template": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "resource_flows_template": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "spillover_rules_template": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "equity_dimensions_template": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "template_id",
    "label",
    "description",
    "parameter_model",
    "scenario_id_template",
    "baseline_version_template",
    "time_horizon",
    "region_pool",
    "indicator_registry_ref_template",
    "intervention_library_ref_template",
    "shock_library_ref_template",
    "policy_pack_ref_template"
  ]
}
