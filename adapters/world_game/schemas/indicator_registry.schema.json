{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/indicator_registry.schema.json",
  "title": "World Game Indicator Registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "registry_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "indicator_definition.schema.json"
      }
    }
  },
  "required": ["registry_id", "label", "indicators"]
}
