{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/event_types.schema.json",
  "type": "object",
  "properties": {
    "allowed_event_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "wg_baseline_loaded"
      },
      "allOf": [
        {
          "contains": {
            "const": "wg_turn_executed"
          }
        },
        {
          "contains": {
            "const": "wg_outcome_projected"
          }
        }
      ]
    }
  },
  "required": ["allowed_event_types"],
  "additionalProperties": false
}
