{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/template_bundle.schema.json",
  "title": "World Game Authoring Template Bundle",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "bundle_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bundle_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "published"]
        },
        "template_version": { "type": "integer", "minimum": 1 },
        "content_version": { "type": "string", "minLength": 1 },
        "deterministic_version_seed": { "type": "string", "minLength": 1 },
        "deterministic_version_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "published_at": { "type": "string", "format": "date-time" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": [
        "bundle_id",
        "label",
        "status",
        "template_version",
        "content_version",
        "deterministic_version_seed",
        "deterministic_version_hash",
        "created_at",
        "updated_at"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": { "const": "published" }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["published_at"]
          }
        }
      ]
    },
    "indicator_registries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "indicator_registry.schema.json"
      }
    },
    "intervention_libraries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "intervention_library.schema.json"
      }
    },
    "shock_libraries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "shock_library.schema.json"
      }
    },
    "scenario_templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "scenario_template.schema.json"
      }
    }
  },
  "required": [
    "bundle_metadata",
    "indicator_registries",
    "intervention_libraries",
    "shock_libraries",
    "scenario_templates"
  ]
}
