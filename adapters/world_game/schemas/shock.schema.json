{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/shock.schema.json",
  "title": "World Game Shock",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "shock_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "applicable_regions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "probability": { "type": "number", "minimum": 0, "maximum": 1 },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region_id": { "type": "string", "minLength": 1 },
          "indicator_id": { "type": "string", "minLength": 1 },
          "delta": { "type": "number" }
        },
        "required": ["region_id", "indicator_id", "delta"]
      }
    },
    "start_turn": { "type": "integer", "minimum": 1 },
    "duration_turns": { "type": "integer", "minimum": 1 }
  },
  "required": ["shock_id", "label", "description", "applicable_regions", "severity", "effects"]
}
