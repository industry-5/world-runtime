{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/comparison_report.schema.json",
  "title": "World Game Branch Comparison Report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "comparison_id": { "type": "string", "minLength": 1 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "branches": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "branch_id": { "type": "string", "minLength": 1 },
          "parent_branch_id": { "type": ["string", "null"] },
          "composite_score": { "type": "number" },
          "indicator_scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "equity": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": ["branch_id", "parent_branch_id", "composite_score", "indicator_scores"]
      }
    },
    "rankings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["comparison_id", "scenario_id", "created_at", "branches", "rankings", "summary"]
}
