{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/entity_types.schema.json",
  "type": "object",
  "properties": {
    "allowed_entity_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "wg_region"
      },
      "allOf": [
        {
          "contains": {
            "const": "wg_indicator_definition"
          }
        },
        {
          "contains": {
            "const": "wg_policy_instrument"
          }
        }
      ]
    }
  },
  "required": ["allowed_entity_types"],
  "additionalProperties": false
}
