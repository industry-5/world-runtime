{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/intervention.schema.json",
  "title": "World Game Intervention",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intervention_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "applicable_regions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "minLength": 1 }
      },
      "required": ["amount", "currency"]
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "latency_turns": { "type": "integer", "minimum": 0 },
    "duration_turns": { "type": "integer", "minimum": 1 },
    "direct_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region_id": { "type": "string", "minLength": 1 },
          "indicator_id": { "type": "string", "minLength": 1 },
          "delta": { "type": "number" },
          "multiplier": { "type": "number", "exclusiveMinimum": 0 }
        },
        "required": ["region_id", "indicator_id"]
      }
    },
    "tradeoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "region_id": { "type": "string", "minLength": 1 },
          "indicator_id": { "type": "string", "minLength": 1 },
          "delta": { "type": "number" },
          "note": { "type": "string" }
        },
        "required": ["region_id", "indicator_id", "delta"]
      }
    },
    "policy_dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": [
    "intervention_id",
    "label",
    "description",
    "applicable_regions",
    "cost",
    "latency_turns",
    "duration_turns",
    "direct_effects"
  ]
}
