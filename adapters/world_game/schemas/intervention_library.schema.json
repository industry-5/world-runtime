{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/intervention_library.schema.json",
  "title": "World Game Intervention Library",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "library_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "interventions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "intervention.schema.json"
      }
    }
  },
  "required": ["library_id", "label", "interventions"]
}
