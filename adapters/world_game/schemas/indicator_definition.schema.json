{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/adapters/world_game/indicator_definition.schema.json",
  "title": "World Game Indicator Definition",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "indicator_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "unit": { "type": "string", "minLength": 1 },
    "direction": {
      "type": "string",
      "enum": ["higher_is_better", "lower_is_better", "target_band"]
    },
    "min_value": { "type": "number" },
    "max_value": { "type": "number" },
    "target": { "type": "number" },
    "target_band": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" }
      },
      "required": ["min", "max"]
    },
    "weight": { "type": "number", "minimum": 0 },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": { "type": "string" }
  },
  "required": ["indicator_id", "label", "description", "unit", "direction"]
}
