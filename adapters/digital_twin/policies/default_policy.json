{
  "policy_id": "policy.digital-twin.default",
  "policy_name": "digital_twin_overlay_controls",
  "policy_type": "overlay_operations",
  "rules": [
    {
      "rule_id": "rule.digital-twin.deny-unverified-host-bindings",
      "rule_name": "Deny overlay actions without verified host bindings",
      "rule_type": "constraint",
      "condition": {
        "field": "proposed_action.parameters.host_bindings_verified",
        "operator": "equals",
        "value": false
      },
      "outcome": "deny",
      "message_template": "Digital twin overlays must stay attached to verified host bindings.",
      "evaluation_mode": "deterministic",
      "severity": "critical",
      "created_at": "2026-03-23T12:00:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.digital-twin.deny-host-writeback",
      "rule_name": "Deny direct overlay writeback into host runtimes",
      "rule_type": "constraint",
      "condition": {
        "field": "proposed_action.parameters.writeback_to_host",
        "operator": "equals",
        "value": true
      },
      "outcome": "deny",
      "message_template": "The public digital-twin slice is advisory only and cannot write directly into host runtimes.",
      "evaluation_mode": "deterministic",
      "severity": "critical",
      "created_at": "2026-03-23T12:00:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.digital-twin.warn-stale-overlay-snapshot",
      "rule_name": "Warn when overlay freshness lags behind the host",
      "rule_type": "advisory",
      "condition": {
        "field": "proposed_action.parameters.freshness_lag_minutes",
        "operator": ">",
        "value": 10
      },
      "outcome": "warn",
      "message_template": "Overlay guidance is older than the preferred host freshness window.",
      "evaluation_mode": "deterministic",
      "severity": "medium",
      "created_at": "2026-03-23T12:00:00Z",
      "version": 1
    },
    {
      "rule_id": "rule.digital-twin.require-approval-cross-host-overlay",
      "rule_name": "Require approval for cross-host overlay expansion",
      "rule_type": "approval_trigger",
      "condition": {
        "field": "proposed_action.parameters.cross_host_binding_count",
        "operator": ">",
        "value": 1
      },
      "outcome": "require_approval",
      "message_template": "Overlay actions spanning more than one host track require operator approval.",
      "evaluation_mode": "deterministic",
      "severity": "high",
      "created_at": "2026-03-23T12:00:00Z",
      "version": 1
    }
  ],
  "default_outcome": "allow",
  "created_at": "2026-03-23T12:00:00Z",
  "version": 1
}
