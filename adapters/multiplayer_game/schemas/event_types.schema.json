  "$id": "https://world-runtime.dev/adapters/multiplayer_game/event_types.schema.json",
  "title": "Multiplayer Game Event Types",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "event_type": {
      "type": "string",
