{
  "stack_id": "stack.supply-network.erp-sync.local",
  "profile": "local",
  "adapter_id": "adapter-supply-network",
  "scenario_path": "examples/scenarios/supply-network-mini",
  "external_systems": [
    {
      "system_id": "erp.sap-s4",
      "role": "system_of_record",
      "interface": "rest",
      "direction": "bidirectional",
      "endpoint": "https://erp.internal.example/api/v1"
    },
    {
      "system_id": "tms.orchestrator",
      "role": "dispatch_execution",
      "interface": "webhook",
      "direction": "outbound",
      "endpoint": "https://tms.internal.example/hooks/routing"
    }
  ],
  "ingress": {
    "event_source": "erp.sap-s4",
    "mode": "poll",
    "poll_interval_seconds": 60,
    "payload_format": "json",
    "retry": {
      "max_attempts": 3
    },
    "event_type_map": {
      "shipment.delay": "shipment_delayed",
      "supplier.outage": "supplier_failed"
    }
  },
  "egress": {
    "target": "tms.orchestrator",
    "mode": "webhook",
    "payload_format": "json",
    "retry": {
      "max_attempts": 3
    },
    "decision_outcomes": [
      "warn",
      "require_approval"
    ],
    "action_type_map": {
      "reroute_shipment": "dispatch.reroute"
    }
  },
  "smoke_test": {
    "projection_name": "world_state",
    "query": "What is the delay status for shipment.88421?",
    "expected_query_type": "shipment_delay"
  },
  "owner": "ops-integrations"
}
