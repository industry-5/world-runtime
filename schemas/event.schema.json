{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/event.schema.json",
  "title": "World Runtime Event",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "recorded_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "actor": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "subject_entities": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/entityRef"
      },
      "default": []
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "causation_id": {
      "$ref": "common.schema.json#/$defs/causationRef"
    },
    "correlation_id": {
      "$ref": "common.schema.json#/$defs/correlationRef"
    },
    "stream_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "recorded_at",
    "payload"
  ]
}
