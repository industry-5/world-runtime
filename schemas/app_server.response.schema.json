{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/app_server.response.schema.json",
  "title": "App Server Response Envelope",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "wire_type": {
      "type": "string",
      "const": "response"
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": { "type": "string" },
        "server_version": { "type": "string" }
      },
      "required": ["policy", "server_version"]
    },
    "id": {
      "type": ["string", "integer", "null"]
    },
    "ok": {
      "type": "boolean"
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["wire_type", "protocol_version", "compatibility", "id", "ok"],
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } } },
      "then": { "required": ["result"] }
    },
    {
      "if": { "properties": { "ok": { "const": false } } },
      "then": { "required": ["error"] }
    }
  ]
}
