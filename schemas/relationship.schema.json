{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/relationship.schema.json",
  "title": "World Runtime Relationship",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "relationship_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "relationship_type": {
      "type": "string",
      "minLength": 1
    },
    "from_entity": {
      "$ref": "common.schema.json#/$defs/entityRef"
    },
    "to_entity": {
      "$ref": "common.schema.json#/$defs/entityRef"
    },
    "attributes": {
      "$ref": "common.schema.json#/$defs/attributes"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "tags": {
      "$ref": "common.schema.json#/$defs/tags"
    },
    "effective_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "expires_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "archived", "deleted"]
    }
  },
  "required": [
    "relationship_id",
    "relationship_type",
    "from_entity",
    "to_entity",
    "created_at",
    "version"
  ]
}
