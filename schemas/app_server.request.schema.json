{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/app_server.request.schema.json",
  "title": "App Server Request Envelope",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "wire_type": {
      "type": "string",
      "const": "request"
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": ["string", "integer"]
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "required": ["protocol_version", "id", "method"]
}
