{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/common.schema.json",
  "title": "World Runtime Common Types",
  "type": "object",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "attributes": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "actorRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actor_id": { "$ref": "#/$defs/id" },
        "actor_type": {
          "type": "string",
          "enum": ["human", "agent", "service", "system", "organization", "unknown"]
        },
        "display_name": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "required": ["actor_id", "actor_type"]
    },
    "entityRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity_id": { "$ref": "#/$defs/id" },
        "entity_type": { "type": "string", "minLength": 1 }
      },
      "required": ["entity_id"]
    },
    "policyOutcome": {
      "type": "string",
      "enum": ["allow", "deny", "warn", "require_approval"]
    },
    "approvalStatus": {
      "type": "string",
      "enum": ["not_required", "pending", "approved", "rejected", "expired", "escalated", "overridden"]
    },
    "decisionStatus": {
      "type": "string",
      "enum": ["draft", "approved", "executed", "rejected", "cancelled"]
    },
    "proposalStatus": {
      "type": "string",
      "enum": ["draft", "submitted", "under_review", "approved", "rejected", "withdrawn", "executed"]
    },
    "causationRef": {
      "type": "string",
      "minLength": 1
    },
    "correlationRef": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_type": { "type": "string", "minLength": 1 },
        "ref_id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string", "minLength": 1 },
        "stage": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "required": ["evidence_type", "ref_id", "summary", "stage"]
    },
    "provenanceStage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "ref_id": { "type": "string", "minLength": 1 },
        "at": { "$ref": "#/$defs/timestamp" },
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "required": ["stage", "status", "ref_id", "at"]
    },
    "provenanceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/provenanceStage" },
          "default": []
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" },
          "default": []
        },
        "evidence_summary": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "required": ["trace", "stages", "evidence", "evidence_summary"]
    }
  }
}
