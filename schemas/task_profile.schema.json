{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/task_profile.schema.json",
  "title": "Task Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_profile_id",
    "task_category",
    "required_capability_tags",
    "required_policy_scope_tags",
    "output_contract",
    "routing_preferences",
    "fallback_policy",
    "approval_sensitivity"
  ],
  "properties": {
    "task_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "task_category": {
      "type": "string",
      "minLength": 1
    },
    "required_capability_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "preferred_capability_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forbidden_capability_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_policy_scope_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_format", "structured_output_required"],
      "properties": {
        "response_format": {
          "type": "string",
          "enum": ["text", "json_object", "json_schema", "vector"]
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "structured_output_required": {
          "type": "boolean"
        }
      }
    },
    "routing_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferred_quality_tier",
        "minimum_quality_tier",
        "preferred_latency_tier",
        "preferred_cost_tier",
        "minimum_determinism_tier"
      ],
      "properties": {
        "preferred_quality_tier": {
          "type": "string",
          "enum": ["economy", "balanced", "high", "premium"]
        },
        "minimum_quality_tier": {
          "type": "string",
          "enum": ["economy", "balanced", "high", "premium"]
        },
        "preferred_latency_tier": {
          "type": "string",
          "enum": ["batch", "interactive", "realtime"]
        },
        "preferred_cost_tier": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "minimum_determinism_tier": {
          "type": "string",
          "enum": ["low", "bounded", "high"]
        }
      }
    },
    "fallback_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "max_quality_tier_downgrade"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "quality_floor"]
        },
        "max_quality_tier_downgrade": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      }
    },
    "approval_sensitivity": {
      "type": "string",
      "enum": ["none", "operator_review", "elevated"]
    }
  }
}
