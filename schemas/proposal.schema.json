{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/proposal.schema.json",
  "title": "World Runtime Action Proposal",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "proposal_id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "proposal_type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "common.schema.json#/$defs/proposalStatus"
    },
    "proposer": {
      "$ref": "common.schema.json#/$defs/actorRef"
    },
    "target_entities": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/entityRef"
      },
      "default": []
    },
    "proposed_action": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "expected_effects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["action_type"]
    },
    "justification": {
      "type": "string"
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "evidence_type": {
            "type": "string",
            "minLength": 1
          },
          "ref_id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          }
        },
        "required": ["evidence_type", "ref_id"]
      },
      "default": []
    },
    "policy_preview": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "policy_name": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "$ref": "common.schema.json#/$defs/policyOutcome"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["policy_name", "outcome"]
      },
      "default": []
    },
    "simulation_refs": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/id"
      },
      "default": []
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "submitted_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    },
    "correlation_id": {
      "$ref": "common.schema.json#/$defs/correlationRef"
    }
  },
  "required": [
    "proposal_id",
    "proposal_type",
    "status",
    "proposer",
    "proposed_action",
    "created_at"
  ]
}
