{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world-runtime.dev/schemas/app_server.notification.schema.json",
  "title": "App Server Notification Envelope",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "wire_type": {
      "type": "string",
      "const": "notification"
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "required": ["wire_type", "protocol_version", "method", "params"]
}
